# Required for authenticated Polymarket trading
POLYMARKET_PRIVATE_KEY=0xyourprivatekey

# Required only if you want to use split / merge
# Also strongly recommended if you want startup approval checks / auto-approve
POLYMARKET_RPC_URL=https://polygon-rpc.com

# Optional operator reporting
TELEGRAM_BOT_TOKENS=123456:ABC-DEF
ADMIN_PASSWORD=change-me-to-a-strong-password

# Optional config overrides for config/default.toml
APP__DATABASE__URL=sqlite:poly-lp.db
APP__ADMIN__PORT=36363
APP__LP__TRADING__CONDITION_ID=0xyourconditionid
APP__LP__APPROVALS__REQUIRE_ON_STARTUP=true
APP__LP__APPROVALS__AUTO_APPROVE_ON_STARTUP=false
APP__LP__CONTROL__BIND_ADDR=127.0.0.1
APP__LP__REPORTING__OPERATOR_CHAT_IDS=[123456789]

# Optional logging override
RUST_LOG=info,poly_lp=info,pn_lp=info,pn_polymarket=info,pn_admin=info
